  "description": "Idiomatic React components for the Qirtaas embeddable rich-text editor.",
  "license": "MIT",
  "author": "Alrimaal",
  "homepage": "https://github.com/alrimaal/qirtaas-js/tree/main/packages/react#readme",
  "repository": {
